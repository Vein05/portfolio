---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbIsland from '../components/blog/BreadcrumbIsland';
import SidebarNav, { MountainDecoration } from '../components/SidebarNav';
import WritingSidebar from '../components/blog/WritingSidebar';
import Experience from '../components/Experience';
import Projects from '../components/Projects';
import Papers from '../components/Papers';
import Honors from '../components/Honors';
import Skills from '../components/Skills';
import Footer from '../components/Footer';
import GitHubContributions from '../components/GitHubContributions';
import { Mail, Linkedin, Github } from '@lucide/astro';

const currentPath = Astro.url.pathname;

const optimizePublicImagePath = (path: string) => {
  if (!path.startsWith('/images/')) return path;
  if (path.startsWith('/images/.optimized/')) return path;

  const lower = path.toLowerCase();
  if (lower.endsWith('.png') || lower.endsWith('.jpg') || lower.endsWith('.jpeg')) {
    return path.replace('/images/', '/images/.optimized/').replace(/\.(png|jpe?g)$/i, '.webp');
  }

  return path;
};

// Netlify Image CDN is only available on Netlify — fall back to raw path in local dev
const netlifyImg = (path: string, params: string) =>
  import.meta.env.DEV ? path : `/.netlify/images?url=${optimizePublicImagePath(path)}&${params}`;
---

<BaseLayout
  title="Sugam Panthi"
  description="Portfolio of Sugam Panthi — software engineer, researcher, and writer based in Hattiesburg, MS."
  canonical="https://sugampanthi.com.np"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebSite",
        "@id": "https://sugampanthi.com.np/#website",
        "url": "https://sugampanthi.com.np",
        "name": "Sugam Panthi",
        "description": "Portfolio of Sugam Panthi — software engineer, researcher, and writer based in Hattiesburg, MS.",
        "author": {
          "@type": "Person",
          "name": "Sugam Panthi",
          "url": "https://sugampanthi.com.np",
          "sameAs": [
            "https://www.linkedin.com/in/sugam-panthi",
            "https://www.github.com/vein05"
          ]
        }
      },
      {
        "@type": "Person",
        "@id": "https://sugampanthi.com.np/#person",
        "name": "Sugam Panthi",
        "url": "https://sugampanthi.com.np",
        "jobTitle": "Software Engineer",
        "alumniOf": "The University of Southern Mississippi",
        "sameAs": [
          "https://www.linkedin.com/in/sugam-panthi",
          "https://www.github.com/vein05"
        ]
      },
      {
        "@type": "SiteLinksSearchBox",
        "url": "https://sugampanthi.com.np",
        "potentialAction": {
          "@type": "SearchAction",
          "target": "https://sugampanthi.com.np/blog?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      },
      {
        "@type": "ItemList",
        "name": "Site Navigation",
        "itemListElement": [
          { "@type": "SiteLinksSearchBox", "@id": "https://sugampanthi.com.np/#sitelinks" },
          { "@type": "ListItem", "position": 1, "name": "About", "url": "https://sugampanthi.com.np/#about" },
          { "@type": "ListItem", "position": 2, "name": "Experience", "url": "https://sugampanthi.com.np/#experience" },
          { "@type": "ListItem", "position": 3, "name": "Projects", "url": "https://sugampanthi.com.np/#projects" },
          { "@type": "ListItem", "position": 4, "name": "Papers", "url": "https://sugampanthi.com.np/#papers" },
          { "@type": "ListItem", "position": 5, "name": "Blog", "url": "https://sugampanthi.com.np/blog" }
        ]
      }
    ]
  })} />

  <div class="min-h-screen bg-paper-light">
    <!-- Breadcrumb — static render + client for location awareness -->
    <BreadcrumbIsland client:load currentPath={currentPath} />

    <div class="w-full grid grid-cols-1 lg:grid-cols-[240px_minmax(0,1fr)_240px] xl:grid-cols-[280px_minmax(0,1fr)_280px] body-container">

      <!-- Left Sidebar — interactive (active section tracking) -->
      <div class="sidebar-panel hidden lg:flex flex-col border-r border-border-paper sticky top-[3.5rem] h-[calc(100vh-3.5rem)]">
        <SidebarNav
          client:load
          title="Sections"
          items={[
            { id: "about", label: "About" },
            { id: "experience", label: "Experience" },
            { id: "projects", label: "Projects" },
            { id: "papers", label: "Papers" },
            { id: "honors", label: "Honors" },
            { id: "skills", label: "Skills" },
          ]}
          activeId="about"
          decoration={true}
          decorationMode="auto-local"
        />
      </div>

      <!-- Main Content — the rest is pure React islands -->
      <main class="w-full px-4 sm:px-8 lg:px-12 pt-4 pb-2 lg:pt-7 lg:pb-4">
        <div id="about" class="header-section">
          <div class="text-center mb-5">
            <p class="text-sm sm:text-base lg:text-lg text-ink-muted font-medium max-w-2xl mx-auto">
              Co-founder @{" "}
              <a href="https://magnoliaed.ai" class="text-ink-blue hover:underline" target="_blank" rel="noopener noreferrer">MagnoliaEd</a>
              {" "}| Research Assistant @{" "}
              <a href="https://www.usm.edu/" class="text-ink-blue hover:underline" target="_blank" rel="noopener noreferrer">The University of Southern Mississippi</a>
            </p>
          </div>

          <div class="mt-5 pb-6 border-b border-border-paper flex flex-col gap-6 lg:grid lg:grid-cols-[minmax(0,1fr)_220px] lg:items-start lg:gap-8">
            <div class="order-2 lg:order-none min-w-0">
              <div class="space-y-3">
                <p class="text-[15px] sm:text-base lg:text-lg text-ink-dark leading-relaxed">
                  I'm Sugam Panthi. I help AI with dementia ;D
                  <br />
                  I'm currently building{" "}
                  <a href="#project-pali" class="text-ink-blue hover:underline font-medium">@Pali</a>
                  {" "}and researching{" "}
                  <a href="#research-conversational-memory" class="text-ink-blue hover:underline font-medium">conversational memory</a>.
                </p>

                <div class="pt-2 space-y-4 lg:hidden">
                  <div class="border border-border-paper bg-paper-surface/70 p-4 sm:p-5">
                    <div class="flex flex-wrap items-center justify-center gap-2 text-center text-sm uppercase tracking-[0.16em] text-ink-muted">
                      <a
                        href="/resume.pdf"
                        class="text-ink-blue hover:text-ink-dark hover:underline underline-offset-4 transition-colors"
                        target="_blank" rel="noopener noreferrer"
                      >
                        View Resume
                      </a>
                      <span class="text-border-paper">/</span>
                      <a
                        href="/resume.pdf"
                        class="text-ink-blue hover:text-ink-dark hover:underline underline-offset-4 transition-colors"
                        download="Sugam_Panthi_Resume.pdf"
                      >
                        Download Resume
                      </a>
                    </div>
                  </div>

                </div>

                <div class="hidden lg:block pt-2">
                  <div class="flex items-center gap-4">
                    <a
                      href="/resume.pdf"
                      class="flex items-center gap-2 px-6 py-2.5 bg-ink-blue text-white rounded-sm hover:bg-opacity-90 transition-all text-sm font-medium"
                      target="_blank" rel="noopener noreferrer"
                    >
                      View Resume
                    </a>
                    <a
                      href="/resume.pdf"
                      class="flex items-center gap-2 px-6 py-2.5 border border-ink-blue text-ink-blue rounded-sm hover:bg-blue-50 transition-all text-sm font-medium"
                      download="Sugam_Panthi_Resume.pdf"
                    >
                      Download Resume
                    </a>
                  </div>

                  <div class="pt-3 max-w-[min(100%,520px)]">
                    <GitHubContributions client:media="(min-width: 1024px)" />
                  </div>
                </div>
              </div>
            </div>

            <div class="order-1 lg:order-none flex flex-col justify-center items-center lg:items-end mb-0 w-full min-w-0">
              <div
                class="relative mx-auto h-[230px] w-[min(100%,220px)] cursor-default rounded-sm outline-none [perspective:1000px] hover:[&_.flip-inner]:[transform:rotateY(180deg)] hover:[&_.flip-inner]:delay-200 active:[&_.flip-inner]:[transform:rotateY(180deg)] active:[&_.flip-inner]:!delay-0 focus-visible:[&_.flip-inner]:[transform:rotateY(180deg)] focus-visible:[&_.flip-inner]:!delay-0 focus-visible:ring-2 focus-visible:ring-ink-blue/45 focus-visible:ring-offset-2 focus-visible:ring-offset-paper-light motion-reduce:hover:[&_.flip-inner]:[transform:none] motion-reduce:active:[&_.flip-inner]:[transform:none] motion-reduce:focus-visible:[&_.flip-inner]:[transform:none]"
                tabindex="0"
                role="group"
                aria-label="Sugam Panthi photo; hover, press, or keyboard focus to see May 2025 and Hattiesburg, MS"
              >
                <div class="flip-inner relative h-full w-full delay-0 transition-transform duration-500 ease-out motion-reduce:transition-none [transform-style:preserve-3d]">
                  <div class="absolute inset-0 h-full w-full overflow-hidden rounded-sm border border-border-paper bg-paper-surface [backface-visibility:hidden]">
                    <img
                      src={netlifyImg('/images/headshot.jpeg', 'w=440&h=460&fit=cover&q=82')}
                      alt=""
                      width="220"
                      height="230"
                      class="h-full w-full object-cover object-bottom opacity-[0.88]"
                      loading="eager"
                      fetchpriority="high"
                    />
                  </div>
                  <div class="absolute inset-0 flex h-full w-full flex-col items-center justify-center gap-1 rounded-sm border border-border-paper bg-paper-surface px-3 text-center [backface-visibility:hidden] [transform:rotateY(180deg)]">
                    <span class="text-[11px] font-mono uppercase tracking-[0.14em] text-ink-muted">May 2025</span>
                    <span class="text-sm text-ink-dark">Hattiesburg, MS</span>
                  </div>
                </div>
              </div>
              <div class="mt-3 flex w-full max-w-[220px] flex-row items-center justify-between gap-2">
                <a href="mailto:Sugam.Panthi@usm.edu" aria-label="Email Sugam.Panthi@usm.edu" class="inline-flex h-10 w-10 shrink-0 items-center justify-center border border-border-paper text-ink-dark hover:text-ink-blue hover:border-ink-blue transition-colors">
                  <Mail class="w-4 h-4 shrink-0" />
                </a>
                <a href="https://www.linkedin.com/in/sugam-panthi" aria-label="LinkedIn — sugam-panthi" target="_blank" rel="noopener noreferrer" class="inline-flex h-10 w-10 shrink-0 items-center justify-center border border-border-paper text-ink-dark hover:text-ink-blue hover:border-ink-blue transition-colors">
                  <Linkedin class="w-4 h-4 shrink-0" />
                </a>
                <a href="https://x.com/SugamPanthi" aria-label="X — @SugamPanthi" target="_blank" rel="noopener noreferrer" class="inline-flex h-10 w-10 shrink-0 items-center justify-center border border-border-paper text-ink-dark hover:text-ink-blue hover:border-ink-blue transition-colors">
                  <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" /></svg>
                </a>
                <a href="https://www.github.com/vein05" aria-label="GitHub — vein05" target="_blank" rel="noopener noreferrer" class="inline-flex h-10 w-10 shrink-0 items-center justify-center border border-border-paper text-ink-dark hover:text-ink-blue hover:border-ink-blue transition-colors">
                  <Github class="w-4 h-4 shrink-0" />
                </a>
              </div>
            </div>
          </div>
        </div>

        <section id="experience" class="mt-8">
          <Experience client:load />
        </section>

        <section id="projects" class="mt-12">
          <Projects client:only="react" />
        </section>

        <section id="papers" class="mt-12">
          <Papers client:only="react" />
        </section>

        <section id="honors" class="mt-12">
          <Honors client:only="react" />
        </section>

        <section id="skills" class="mt-12">
          <Skills client:load />
        </section>

        <Footer client:load />

        <div class="mt-10 -mx-4 sm:-mx-8 overflow-hidden lg:hidden">
          <MountainDecoration client:load mode="auto-local" />
        </div>
      </main>

      <!-- Right Sidebar -->
      <div class="hidden lg:block">
        <WritingSidebar client:media="(min-width: 1024px)" limit={6} />
      </div>
    </div>
  </div>

  <!-- Active section scroll tracking — runs client-side -->
  <script>
    const sections = ['about', 'experience', 'projects', 'papers', 'honors', 'skills'];

    function getActive() {
      const nearBottom = window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 8;
      if (nearBottom) return sections[sections.length - 1];

      const readingLine = window.innerHeight * 0.35;
      let current = sections[0];

      for (const id of sections) {
        const el = document.getElementById(id);
        if (!el) continue;
        const { top, bottom } = el.getBoundingClientRect();
        if (top <= readingLine && bottom > readingLine) { current = id; break; }
        if (bottom <= readingLine) current = id;
      }
      return current;
    }

    function updateActive() {
      const active = getActive();
      document.querySelectorAll('[data-section-id]').forEach((el) => {
        const id = el.getAttribute('data-section-id');
        if (id === active) {
          el.classList.add('scale-x-100');
          el.classList.remove('scale-x-0');
        } else {
          el.classList.remove('scale-x-100');
          el.classList.add('scale-x-0');
        }
      });
      document.querySelectorAll('[data-section-link]').forEach((el) => {
        const id = el.getAttribute('data-section-link');
        if (id === active) {
          el.classList.add('text-paper-light');
          el.classList.remove('text-ink-dark', 'hover:text-ink-blue');
        } else {
          el.classList.remove('text-paper-light');
          el.classList.add('text-ink-dark', 'hover:text-ink-blue');
        }
      });
    }

    window.addEventListener('scroll', updateActive, { passive: true });
    updateActive();
  </script>
</BaseLayout>
